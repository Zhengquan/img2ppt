# =============================================================================
# 图片/PDF 转 PPT - 环境变量示例
# 复制为 .env 后填写：cp .env.example .env
# OCR 至少配置一种（腾讯或百度）。若两种都配置，默认优先腾讯。
# =============================================================================

# -----------------------------------------------------------------------------
# 腾讯云 - OCR（推荐）
# 通用文字识别（高精度版）：https://cloud.tencent.com/document/product/866/34937
# -----------------------------------------------------------------------------
TENCENT_OCR_SECRET_ID=your-secret-id
TENCENT_OCR_SECRET_KEY=your-secret-key
TENCENT_OCR_REGION=ap-guangzhou

# -----------------------------------------------------------------------------
# 百度智能云 - OCR（可选）
# 在百度智能云控制台创建应用，开通「通用文字识别（高精度含位置版）」，
# 获取 API Key 与 Secret Key，需实名认证。有免费额度。
# -----------------------------------------------------------------------------
BAIDU_OCR_API_KEY=your-api-key
BAIDU_OCR_SECRET_KEY=your-secret-key

# -----------------------------------------------------------------------------
# 其他可选（图像修复等，当前项目未使用）
# -----------------------------------------------------------------------------
# BAIDU_IMAGE_REPAIR_API_KEY=
# BAIDU_IMAGE_REPAIR_SECRET_KEY=
